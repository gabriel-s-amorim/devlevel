# PostgreSQL (Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/devlevel?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-at-least-32-chars-long-here"
AUTH_URL="http://localhost:3000"

# Optional: Upstash Redis for serverless rate limiting (login/register)
# Without these, rate limiting falls back to a no-op in development
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
